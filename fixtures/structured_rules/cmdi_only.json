{
  "schema_version": 1,
  "features": {
    "surface": {
      "fields": [
        "path",
        "query.keys",
        "query.values",
        "body"
      ],
      "normalization": ["lowercase"],
      "max_collection_entries": {
        "query": 1000,
        "headers": 1000
      },
      "max_scalar_bytes": {
        "method": 4096,
        "path": 1048576,
        "query.item": 1048576,
        "header.item": 1048576
      },
      "body_scan": {
        "mode": "full",
        "max_bytes": 1048576
      }
    }
  },
  "rules": [
    {
      "id": "symbolic_cmdi",
      "field": "surface",
      "operator": "contains_literal",
      "literal": "command_delimiter_indicator",
      "signal": "symbolic_cmdi",
      "confidence": 0.86
    }
  ],
  "decision": {
    "block_when": "any_rule_matches",
    "reason": "command delimiter indicator matched",
    "confidence_strategy": {
      "type": "fixed",
      "default": 0.86
    },
    "matched_signals": "matched_rule_signals"
  },
  "fallback": {
    "blocked": false,
    "reason": "no command delimiter indicator matched",
    "confidence": 0.0,
    "matched_signals": []
  }
}
